# =============================================================================
# Wallpaper Setter — docker/.env
# Copy this file to `.env` and tweak as needed:
#   cp docker/.env.example docker/.env
# =============================================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=root
POSTGRES_PASSWORD=root
POSTGRES_DB=wallpaper_setter
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
# Leave empty to disable auth (matches the project's redis.ts behaviour)
REDIS_PASSWORD=

# ---------- MinIO ----------
MINIO_ROOT_USER=myadmin
MINIO_ROOT_PASSWORD=myadminpwd
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=wallpapers
MINIO_USE_SSL=false

# ---------- Server (backend) ----------
SERVER_PORT=3000
NODE_ENV=production
# Built-in image tag, override to pull from a registry if you publish one
SERVER_IMAGE_TAG=dev

# ---------- Backend secrets ----------
# IMPORTANT: change this in any non-dev environment
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ---------- WeChat login (optional, leave blank in dev) ----------
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback
