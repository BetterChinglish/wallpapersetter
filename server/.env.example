# Environment
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL="postgresql://root:root@localhost:5432/wallpaper_setter?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=myadmin
MINIO_SECRET_KEY=myadminpwd
MINIO_BUCKET_NAME=wallpapers

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# WeChat Login (to be configured)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://localhost:3000/api/auth/wechat/callback
