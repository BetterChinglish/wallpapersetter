// Prisma Schema for Wallpaper Setter Backend
// Database: PostgreSQL 16+
// Generated: 2026-06-15

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== User Models =====

model User {
  id        String   @id @default(uuid())
  openid    String?  @unique // WeChat openid
  email     String?  @unique
  username  String?  @unique
  nickname  String?
  avatarUrl String?
  password  String? // For email login
  role      UserRole @default(USER)

  // Relations
  wallpapers Wallpaper[] @relation("WallpaperAuthor")
  sessions   Session[] // 添加这行 - Session 反向引用
  favorites  Favorite[]
  downloads  Download[]
  likes      Like[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

// ===== Wallpaper Models =====

model Wallpaper {
  id          String        @id @default(uuid())
  title       String        @db.VarChar(128)
  description String?       @db.Text
  type        WallpaperType

  // Content
  contentUrl String? // For web wallpapers: file path or URL
  videoLocal Boolean @default(false) // Is video played locally?

  // Media
  thumbnailUrl String?
  fileSize     Int? // File size in bytes

  // Relations
  authorId String
  author   User   @relation("WallpaperAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  favorites Favorite[]
  downloads Download[]
  likes     Like[]

  viewCount     Int @default(0)
  downloadCount Int @default(0)
  likeCount     Int @default(0)

  isPublished Boolean @default(false)
  isApproved  Boolean @default(false) // Admin approval

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([authorId])
  @@index([createdAt])
  @@index([isPublished, isApproved])
  @@map("wallpapers")
}

enum WallpaperType {
  VIDEO
  WEB
}

// ===== Interaction Models =====

model Favorite {
  id          String    @id @default(uuid())
  userId      String
  wallpaperId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallpaper   Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, wallpaperId])
  @@map("favorites")
}

model Download {
  id          String    @id @default(uuid())
  userId      String
  wallpaperId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallpaper   Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@map("downloads")
}

model Like {
  id          String    @id @default(uuid())
  userId      String
  wallpaperId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallpaper   Wallpaper @relation(fields: [wallpaperId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, wallpaperId])
  @@map("likes")
}

// ===== Session Models =====

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}
